{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lumina AI Chat",
  "version": "1.0.0",
  "identifier": "com.lumina.aichat",
  "build": {
    "beforeDevCommand": "npm run dev:server",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:3000",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Lumina AI Chat",
        "width": 1440,
        "height": 980,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "center": true,
        "decorations": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../public/icon.svg"
    ]
  }
}
