    "pdf-parse": "^2.4.5",
    "playwright-core": "^1.53.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-force-graph-2d": "^1.27.0",
    "react-markdown": "^10.1.0",
