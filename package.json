{
  "name": "lumina-ai-chat",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx server.ts",
    "dev:server": "cross-env NODE_ENV=development tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "build:electron": "esbuild electron/main.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist-electron/main.cjs && esbuild electron/preload.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist-electron/preload.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "dev:app": "npm run build:electron && concurrently --kill-others \"cross-env NODE_ENV=development tsx server.ts\" \"wait-on http://localhost:3000/api/health && electron .\"",
    "electron:dev": "npm run build:electron && concurrently --kill-others \"cross-env NODE_ENV=development tsx server.ts\" \"wait-on http://localhost:3000/api/health && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "clean": "rm -rf dist dist-electron server.js",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "build": {
    "appId": "com.lumina.aichat",
    "productName": "Lumina AI Chat",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "assets/**/*",
      "loading.html",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist",
        "to": "dist"
      },
      {
        "from": "dist-electron",
        "to": "dist-electron"
      },
      {
        "from": "assets",
        "to": "assets"
      },
      {
        "from": "loading.html",
        "to": "loading.html"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/sparkles.png"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/sparkles.png"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "assets/sparkles.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.141",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^4.4.3",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.16.1",
    "cheerio": "^1.2.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "duck-duck-scrape": "^2.2.7",
    "express": "^4.21.2",
    "gguf": "^1.0.7",
    "lucide-react": "^0.546.0",
    "mammoth": "^1.12.0",
    "motion": "^12.23.24",
    "nodejs-whisper": "^0.3.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "systeminformation": "^5.31.7",
    "turndown": "^7.2.4",
    "uuid": "^14.0.0",
    "vite": "^6.2.3",
    "vite-plugin-pwa": "^1.3.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^42.3.2",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "wait-on": "^9.0.10"
  },
  "allowScripts": {
    "electron@42.3.0": true
  }
}
