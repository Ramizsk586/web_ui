{
  "name": "lumina-ai-chat",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx server.ts",
    "dev:server": "cross-env NODE_ENV=development tsx server.ts",
    "build:server": "node -e \"const fs=require('fs');if(!fs.existsSync('dist'))fs.mkdirSync('dist')\" && esbuild server.ts --bundle --platform=node --format=esm --sourcemap --outfile=dist/server.mjs --external:vite --external:playwright-core --external:crawlee --external:chromium-bidi --external:chromium-bidi/* --external:onnxruntime-node --external:nodejs-whisper --external:@huggingface/transformers --external:@anthropic-ai/claude-agent-sdk",
    "build": "vite build && npm run build:server",
    "start": "node dist/server.mjs",
    "preview": "vite preview",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.84",
    "@ai-sdk/cohere": "^3.0.38",
    "@ai-sdk/google": "^3.0.82",
