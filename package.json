    "@ai-sdk/openai": "^3.0.71",
    "@ai-sdk/openai-compatible": "^2.0.50",
    "@anthropic-ai/claude-agent-sdk": "^0.2.141",
    "@anthropic-ai/sdk": "^0.104.1",
    "@composio/claude-agent-sdk": "^0.9.2",
    "@composio/core": "^0.10.0",
    "@earendil-works/pi-agent-core": "^0.79.3",
