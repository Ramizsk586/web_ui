{
  "name": "lumina-ai-chat",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx server.ts",
    "dev:server": "cross-env NODE_ENV=development tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "dev:app": "tauri dev",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "clean": "node -e \"const fs=require('fs'); for (const p of ['dist','src-tauri/target']) fs.rmSync(p, { recursive: true, force: true });\"",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.16.1",
    "cheerio": "^1.2.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "duck-duck-scrape": "^2.2.7",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "tesseract.js": "^7.0.0",
    "turndown": "^7.2.4",
    "vite": "^6.2.3",
    "vite-plugin-pwa": "^1.3.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "wait-on": "^9.0.10"
  },
  "allowScripts": {}
}
